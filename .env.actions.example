# Image
SUB2API_IMAGE=ghcr.io/zwenooo/sub2api:latest

# Network
BIND_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

# PostgreSQL
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=Wangge667
POSTGRES_DB=sub2api
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=sub2api
DATABASE_PASSWORD=Wangge667
DATABASE_DBNAME=sub2api
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=Wangge667
REDIS_DB=0
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

# Bootstrap / auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
JWT_SECRET=replace-with-a-fixed-secret
JWT_EXPIRE_HOUR=24
TOTP_ENCRYPTION_KEY=replace-with-a-fixed-secret

# App logs: bounded file rotation
LOG_LEVEL=info
LOG_FORMAT=console
LOG_SERVICE_NAME=sub2api
LOG_ENV=production
LOG_CALLER=true
LOG_STACKTRACE_LEVEL=error
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=true
LOG_OUTPUT_FILE_PATH=/app/data/logs/sub2api.log
LOG_ROTATION_MAX_SIZE_MB=100
LOG_ROTATION_MAX_BACKUPS=10
LOG_ROTATION_MAX_AGE_DAYS=7
LOG_ROTATION_COMPRESS=true
LOG_ROTATION_LOCAL_TIME=true

# Docker logs: bounded json-file rotation
DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=5
